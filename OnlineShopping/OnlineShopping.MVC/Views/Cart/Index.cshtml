@model List<CartViewModel>

@{
    ViewData["Title"] = "Your Cart";
    var total = Model.Sum(x => x.Price * x.Quantity);
}

<div class="container mt-5">

    <h2 class="text-center mb-4">🛒 Your Shopping Cart</h2>

    <table class="table table-bordered table-hover shadow">
        <thead class="table-dark text-center">
            <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
            </tr>
        </thead>

        <tbody class="text-center align-middle">
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.ImageUrl" width="80" class="rounded shadow-sm" />
                    </td>
                    <td class="fw-bold">@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>₹@item.Price</td>
                    <td class="text-success fw-bold">
                        ₹@(item.Price* item.Quantity)
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- TOTAL SECTION -->
    <div class="text-end mt-4">
        <h4>
            Total Amount:
            <span class="text-success fw-bold">₹@total</span>
        </h4>
    </div>

    <!-- BUTTONS -->
    <div class="d-flex justify-content-between mt-4">
        <a href="/Product" class="btn btn-outline-primary">
            ⬅ Continue Shopping
        </a>

        <a href="/Order/Checkout" class="btn btn-success px-4">
            🚀 Proceed to Checkout
        </a>
    </div>

</div>